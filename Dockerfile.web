FROM python:3.11-slim

# Install system dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    ffmpeg \
    git \
    gcc \
    python3-dev \
    curl \
    ca-certificates \
    gnupg \
    libnss3 \
    libnspr4 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libdbus-1-3 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libpango-1.0-0 \
    libcairo2 \
    libasound2 \
    libatspi2.0-0 \
    fonts-unifont \
    fonts-liberation \
    && curl -fsSL https://deno.land/x/install/install.sh | sh \
    && rm -rf /var/lib/apt/lists/*

ENV DENO_INSTALL="/root/.deno"
ENV PATH="$DENO_INSTALL/bin:$PATH"

WORKDIR /app

# Install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install Playwright browsers
RUN playwright install chromium || true

# Copy project files
COPY . .

# Ensure youtube_api exists
RUN if [ ! -d "youtube_api" ]; then \
    git clone https://github.com/akilaramal69-beep/ytnew youtube_api; \
    fi

# Create downloads directory
RUN mkdir -p DOWNLOADS youtube_api/downloads

# Set environment variables
ENV FFMPEG_PATH=/usr/bin/ffmpeg
ENV PORT=8080

# Expose port for Flask app
EXPOSE 8080

# Run the web app (no Telegram bot)
CMD ["python", "app_web.py"]
